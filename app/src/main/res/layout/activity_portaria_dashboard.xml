<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- CONTENU PRINCIPAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F2F2F2">

        <!-- HEADER -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0D47A1"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end|center_vertical"
                android:layout_gravity="end"
                android:orientation="horizontal"
                android:layout_marginTop="11dp">

                <ImageView
                    android:id="@+id/ivNotification"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_notification"
                    app:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/tvMenu"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:text="⋮"
                    android:textColor="#FFFFFF"
                    android:textSize="25sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSaudacao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aqui, Portaria "
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="-10dp"/>

            <TextView
                android:id="@+id/tvTituloDashboard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Condomínio Pinheiro"
                android:textColor="#E3F2FD"
                android:textSize="14sp"/>

        </LinearLayout>

        <!-- CONTENT -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/contentArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingBottom="100dp">

                <!-- RESUMO -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Resumo da Portaria"
                    android:textColor="#222222"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- PENDENTES -->
                    <LinearLayout
                        android:id="@+id/cardPendentes"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_margin="6dp"
                        android:background="#FFFFFF"
                        android:elevation="3dp"
                        android:padding="12dp"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:text="Pendentes"
                            android:textColor="#1E4FA3"
                            android:textStyle="bold"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/tvPendentesCount"
                            android:text="0"
                            android:textColor="#1E4FA3"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"/>

                        <TextView
                            android:text="Aguardando retirada"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:textColor="#777777"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- NOVA HOJE -->
                    <LinearLayout
                        android:id="@+id/cardNovasHoje"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_margin="6dp"
                        android:background="#FFFFFF"
                        android:elevation="3dp"
                        android:padding="12dp"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:text="Nova hoje"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:textColor="#2E7D32"
                            android:textStyle="bold"
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/tvNovasCount"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="0"
                            android:textColor="#2E7D32"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"/>

                        <TextView
                            android:text="Recebidas hoje"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:textColor="#777777"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- RETIRADAS -->
                    <LinearLayout
                        android:id="@+id/cardRetiradas"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_margin="6dp"
                        android:background="#FFFFFF"
                        android:elevation="3dp"
                        android:padding="12dp"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:text="Retiradas"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:textColor="#6A1B9A"
                            android:textStyle="bold"
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/tvRetiradasCount"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="0"
                            android:textColor="#6A1B9A"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"/>

                        <TextView
                            android:text="Já entregues"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:textColor="#777777"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- MESSAGE -->
                <LinearLayout
                    android:id="@+id/alertContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_alert"
                    android:padding="16dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- ICON -->
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_dialog_alert"
                        android:tint="#D32F2F"
                        android:layout_marginEnd="12dp"/>

                    <!-- TEXTS -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvAlertTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="6 encomendas aguardando retirada"
                            android:textColor="#222222"
                            android:textStyle="bold"
                            android:textSize="14sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não deixe acumular. Avise os moradores."
                            android:textColor="#666666"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- ACTIONS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:text="Ações rápidas"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textColor="#222222"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btnNovaEncomendaRapida"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Nova Encomenda"
                        android:textAllCaps="false"
                        android:layout_marginBottom="10dp" />

                    <Button
                        android:id="@+id/btnVerPendentesRapido"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Ver Pendentes"
                        android:textAllCaps="false"
                        android:layout_marginBottom="10dp" />

                    <Button
                        android:id="@+id/btnVerHistoricoRapido"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Ver Histórico"
                        android:textAllCaps="false"
                        android:layout_marginBottom="10dp" />

                    <Button
                        android:id="@+id/btnMoradores"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Ver Moradores"
                        android:textAllCaps="false" />

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabNova"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:contentDescription="Nova Encomenda"
        app:srcCompat="@drawable/ic_add"
        app:tint="@android:color/white"
        app:backgroundTint="#2E7D32" />

</FrameLayout>