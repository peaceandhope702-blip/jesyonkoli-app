<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6F8"
    android:fitsSystemWindows="true">

    <!-- HEADER -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="#0D47A1"
        android:paddingTop="28dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Detalhe da Encomenda"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- FOTO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/imgFotoDetalhe"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:scaleType="centerCrop"
                    android:background="#EEEEEE" />

            </androidx.cardview.widget.CardView>

            <!-- INFOS -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#FFFFFF">

                    <!-- TOP ROW -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- LEFT -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDestinatarioDetalhe"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kado1"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#1F2933"/>

                            <TextView
                                android:id="@+id/tvSubInfo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="C6 • Y"
                                android:textSize="14sp"
                                android:textColor="#78909C"
                                android:layout_marginTop="2dp"/>

                        </LinearLayout>

                        <!-- RIGHT -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:id="@+id/tvStatusDetalhe"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PENDENTE"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"
                                android:background="@drawable/bg_status_badge_pendente" />

                            <TextView
                                android:id="@+id/tvTotalEncomendas"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 encomendas"
                                android:textSize="12sp"
                                android:textColor="#0D47A1"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ASSINATURA -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:text="Assinatura"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>

                    <ImageView
                        android:id="@+id/imgAssinaturaDetalhe"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:background="#FAFAFA"
                        android:scaleType="fitCenter" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- BOUTON CACHE (pa efase pou pa kraze Java) -->
            <Button
                android:id="@+id/btnRetirarTodos"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnEditar"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <!-- BOUTON PRINCIPAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="16dp">

        <Button
            android:id="@+id/btnRetirarSomente"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Retirar encomenda"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:background="@drawable/bg_button_primary"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</LinearLayout>